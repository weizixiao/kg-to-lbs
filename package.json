{
  "name": "kg-to-lbs",
  "version": "0.1.0",
  "description": "Small TypeScript utilities for converting kilograms, pounds, ounces, and stones.",
  "keywords": [
    "kg",
    "lbs",
    "kilograms",
    "pounds",
    "weight",
    "converter",
    "conversion"
  ],
  "homepage": "https://kgtolbs.org",
  "bugs": {
    "url": "https://github.com/weizixiao/kg-to-lbs/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/weizixiao/kg-to-lbs.git"
  },
  "license": "MIT",
  "author": "winter",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "directories": {
    "test": "test"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "prepublishOnly": "npm test",
    "test": "npm run build && node --test test/conversion.test.mjs",
    "pack:dry-run": "npm pack --dry-run"
  },
  "devDependencies": {
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false
}
